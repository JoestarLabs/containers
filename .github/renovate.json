{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Group all caddy-docker-cloudflare updates together",
      "matchPaths": ["caddy-docker-cloudflare/**"],
      "groupName": "Caddy Image Dependencies"
    },
    {
      "description": "Group all plezy-relay updates (Go modules and Docker base image) together",
      "matchPaths": ["plezy-relay/**"],
      "groupName": "Plezy Relay Dependencies"
    }
  ]
}
